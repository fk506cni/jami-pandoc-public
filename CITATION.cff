    given-names: Keita
    affiliation: "Division of Medical Information Technology and Administration Planning, Department of Medical Informatics, Kyoto University Hospital"
  - family-names: Mori
    given-names: Yukiko
    affiliation: "Kyoto University Hospital"
  - family-names: Kuroda
    given-names: Tomohiro
    affiliation: "Kyoto University Hospital"
version: "0.1.0"
